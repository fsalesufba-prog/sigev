# ====================================
# FILE UPLOAD
# ====================================
MAX_FILE_SIZE=52428800
UPLOAD_PATH="./uploads"
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,audio/mpeg,audio/wav,video/mp4"

# ====================================
# RATE LIMIT
# ====================================
RATE_LIMIT_MAX=200
RATE_LIMIT_TIME_WINDOW=60000

# ====================================
# HOSTINGER CONFIG
# ====================================
HOSTINGER_PRO="true"
MAX_REQUEST_SIZE="50mb"

# ====================================
# SEGURANÇA SSL
# ====================================
SSL_ENABLED="true"
TRUST_PROXY="true"

# ====================================
# CORS
# ====================================
CORS_ORIGIN="https://sigev.sqtecnologiadainformacao.com"

# ====================================
# CACHE E SESSÃO
# ====================================
SESSION_TIMEOUT=28800000
CACHE_TTL=3600000

# ====================================
# LOGS
# ====================================
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# ====================================
# REMOVER CONFIGURAÇÕES NÃO UTILIZADAS
# ====================================
# RECARGAPAY - NÃO USADO NO SIGEV
# WHATSAPP - NÃO USADO NO SIGEV
